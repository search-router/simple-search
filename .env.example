APP_ENV=dev
APP_CONFIG_FILE=config.yaml
LOG_LEVEL=INFO

# Search Router. Leave blank to run on a deterministic mock backend.
SEARCH_ROUTER_API_KEY=

# Optional Redis cache. Leave blank to run with NullCache.
REDIS_URL=

# Required to access /api/v1/health and /api/v1/backends. Leave blank in dev
# to keep these endpoints open with a startup warning.
ADMIN_TOKEN=

# Session cookie secret used by the ads cabinet. Leave blank in dev to get
# an ephemeral random secret per process (sessions reset on restart). In prod
# set ads.require_session_secret=true in config.yaml so an unset value fails
# the app at startup instead of silently invalidating sessions.
SESSION_SECRET=
